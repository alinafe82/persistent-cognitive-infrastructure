# Local development defaults only. Do not put real secrets in this file.

PCI_SERVICE_NAME=pci-control-plane
PCI_ENVIRONMENT=local
PCI_DATABASE_URL=postgresql://pci:pci@postgres:5432/pci # pragma: allowlist secret # gitleaks:allow
PCI_NATS_URL=nats://nats:4222
PCI_TEMPORAL_ADDRESS=temporal:7233
PCI_POLICY_BUNDLE_VERSION=local-dev
PCI_ENABLE_OPENAPI=true

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
